@inject IMcpService McpService
@inject ISnackbar Snackbar

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <div class="typo-h6">
            <MudIcon Icon="@Icons.Material.Filled.Hub" Class="mr-2"/>
            MCP 서버 관리
        </div>
    </TitleContent>
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Elevation="0" Rounded="true" ApplyEffectsToContainer="true">

            @* ── Tab 0: Server List ─────────────────────────────────────────── *@
            <MudTabPanel Text="서버 목록" Icon="@Icons.Material.Filled.List">
                @if (_loading)
                {
                    <div style="display: flex; justify-content: center; padding: 24px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small"/>
                    </div>
                }
                else if (_servers.Count == 0)
                {
                    <div class="pa-4 text-center">
                        <p class="typo-body2 text-secondary">등록된 MCP 서버가 없습니다.</p>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   Class="mt-2" OnClick="@(() => _activeTabIndex = 1)">
                            빠른 추가로 시작하기
                        </MudButton>
                    </div>
                }
                else
                {
                    <div class="mcp-server-list">
                        @foreach (var server in _servers)
                        {
                            <div class="mcp-server-card">
                                <div class="mcp-server-card-header">
                                    @* Connection status indicator *@
                                    @switch (server.Status.ConnectionStatus)
                                    {
                                        case McpConnectionStatus.Checking:
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                                  Style="width:16px;height:16px;"/>
                                            break;
                                        case McpConnectionStatus.Reachable:
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Color="Color.Success"
                                                     Size="Size.Small" Style="width:16px;height:16px;"/>
                                            break;
                                        case McpConnectionStatus.Unreachable:
                                            <MudTooltip Text="@server.Status.Error">
                                                <MudIcon Icon="@Icons.Material.Filled.Cancel"
                                                         Color="Color.Error"
                                                         Size="Size.Small" Style="width:16px;height:16px;"/>
                                            </MudTooltip>
                                            break;
                                        case McpConnectionStatus.Error:
                                            <MudTooltip Text="@server.Status.Error">
                                                <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                         Color="Color.Warning"
                                                         Size="Size.Small" Style="width:16px;height:16px;"/>
                                            </MudTooltip>
                                            break;
                                        default:
                                            <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked"
                                                     Color="Color.Default"
                                                     Size="Size.Small" Style="width:16px;height:16px;opacity:0.4;"/>
                                            break;
                                    }
                                    <MudIcon Icon="@GetTransportIcon(server)" Size="Size.Small"
                                             Style="width:16px;height:16px;opacity:0.6;"/>
                                    <span class="typo-subtitle2">@server.Name</span>
                                    <div style="margin-left: auto; display: flex; gap: 2px; align-items: center;">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Color="@(IsCloudServer(server) ? Color.Info : Color.Default)">
                                            @(IsCloudServer(server) ? "클라우드" : "로컬")
                                        </MudChip>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Color="@GetScopeColor(server.Scope)">
                                            @GetScopeLabel(server.Scope)
                                        </MudChip>
                                        <MudTooltip Text="연결 테스트">
                                            <MudIconButton Icon="@Icons.Material.Filled.NetworkCheck"
                                                           Size="Size.Small" Color="Color.Default"
                                                           OnClick="@(() => TestConnection(server))"/>
                                        </MudTooltip>
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => StartEdit(server))"/>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => RemoveServer(server))"/>
                                    </div>
                                </div>
                                <div class="mcp-server-card-detail typo-caption text-secondary">
                                    @if (server.Transport == "stdio")
                                    {
                                        <span>@server.Command @(server.Args.Count > 0 ? string.Join(" ", server.Args) : "")</span>
                                    }
                                    else if (!string.IsNullOrEmpty(server.Url))
                                    {
                                        <span>@server.Url</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                <div style="padding: 8px; display: flex; gap: 4px;">
                    <MudButton StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                               Variant="Variant.Text" OnClick="RefreshServers">새로고침
                    </MudButton>
                    @if (_servers.Count > 0)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.NetworkCheck" Size="Size.Small"
                                   Variant="Variant.Text" OnClick="TestAllConnections"
                                   Disabled="_testingAll">
                            @if (_testingAll)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                     Style="width:14px;height:14px;margin-right:4px;"/>
                            }
                            모두 테스트
                        </MudButton>
                    }
                </div>
            </MudTabPanel>

            @* ── Tab 1: Quick Add ───────────────────────────────────────────── *@
            <MudTabPanel Text="빠른 추가" Icon="@Icons.Material.Filled.Bolt">
                <div class="pa-3">
                    <p class="typo-body2 text-secondary mb-3">
                        인기 MCP 서버를 한 번에 추가하세요. 카드를 클릭하면 설정이 자동으로 채워집니다.
                    </p>
                    <div class="mcp-template-grid">
                        @foreach (var t in _mcpTemplates)
                        {
                            <div class="mcp-template-card" @onclick="@(() => ApplyTemplate(t))">
                                <div class="typo-subtitle2 mb-1">@t.Name</div>
                                <div class="typo-caption text-secondary">@t.Description</div>
                                @if (t.McpEnv?.Count > 0)
                                {
                                    <div class="mt-1">
                                        @foreach (var key in t.McpEnv.Keys)
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="Color.Warning" Class="mr-1">
                                                @key
                                            </MudChip>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </MudTabPanel>

            @* ── Tab 2: Manual Add/Edit ─────────────────────────────────────── *@
            <MudTabPanel Text="@(_editingServer != null ? "서버 수정" : "수동 추가")"
                         Icon="@(_editingServer != null ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)">
                <div class="stack gap-3 pa-3">
                    <MudTextField @bind-Value="_newName" Label="서버 이름" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Required="true"/>

                    <MudSelect T="string" @bind-Value="_newTransport" Label="전송 방식"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("stdio")">stdio (로컬 프로세스)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("sse")">SSE / HTTP (원격 서버)</MudSelectItem>
                    </MudSelect>

                    @if (_newTransport == "stdio")
                    {
                        <MudTextField @bind-Value="_newCommand" Label="명령어" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Placeholder="npx, node, python..."
                                      Required="true"/>

                        @* Args as individual list items *@
                        <div>
                            <div class="typo-subtitle2 mb-1">인수 (Arguments)</div>
                            @for (var i = 0; i < _argsList.Count; i++)
                            {
                                var capturedIdx = i;
                                var isPlaceholder = _argPlaceholders.Contains(_argsList[capturedIdx]);
                                <div class="stack-row gap-1 items-center mb-1">
                                    <MudTextField T="string"
                                                  Value="@_argsList[capturedIdx]"
                                                  ValueChanged="@(v => _argsList[capturedIdx] = v)"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Style="@(isPlaceholder ? "flex:1;border-color:var(--mud-palette-warning);" : "flex:1;")"
                                                  Placeholder="@(isPlaceholder ? "경로를 입력하세요" : "")"/>
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                   OnClick="@(() => RemoveArg(capturedIdx))"/>
                                </div>
                            }
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                                       Variant="Variant.Text" OnClick="AddArg">인수 추가
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <MudTextField @bind-Value="_newUrl" Label="서버 URL" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Placeholder="http://localhost:3000/sse"
                                      Required="true"/>
                    }

                    <MudSelect T="string" @bind-Value="_newScope" Label="범위"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@("user")">사용자 (전역)</MudSelectItem>
                        <MudSelectItem T="string" Value="@("project")">프로젝트</MudSelectItem>
                        <MudSelectItem T="string" Value="@("local")">로컬</MudSelectItem>
                    </MudSelect>

                    @* Environment Variables *@
                    <div>
                        <div class="typo-subtitle2 mb-1">환경변수</div>
                        @foreach (var (key, idx) in _envKeys.Select((k, i) => (k, i)))
                        {
                            var capturedIdx = idx;
                            <div class="stack-row gap-1 items-center mb-1">
                                <MudTextField T="string" Value="@_envKeys[capturedIdx]"
                                              ValueChanged="@(v => _envKeys[capturedIdx] = v)"
                                              Placeholder="KEY" Variant="Variant.Outlined" Margin="Margin.Dense"
                                              Style="flex: 0.4;"/>
                                <MudTextField T="string" Value="@_envValues[capturedIdx]"
                                              ValueChanged="@(v => _envValues[capturedIdx] = v)"
                                              Placeholder="VALUE" Variant="Variant.Outlined" Margin="Margin.Dense"
                                              Style="flex: 0.6;" InputType="InputType.Password"/>
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                               OnClick="@(() => RemoveEnvRow(capturedIdx))"/>
                            </div>
                        }
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Text"
                                   OnClick="AddEnvRow">환경변수 추가
                        </MudButton>
                    </div>

                    @if (!string.IsNullOrEmpty(_formError))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_formError</MudAlert>
                    }

                    <div class="stack-row gap-2 items-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(_editingServer != null ? SaveEdit : AddServer)"
                                   Disabled="@(IsFormInvalid() || _saving)">
                            @if (_saving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                     Style="width:16px;height:16px;margin-right:6px;"/>
                            }
                            @(_editingServer != null ? "저장" : "서버 추가")
                        </MudButton>
                        @if (_editingServer != null)
                        {
                            <MudButton Variant="Variant.Text" OnClick="CancelEdit">취소</MudButton>
                        }
                        @if (_editingServer == null)
                        {
                            <MudCheckBox T="bool" @bind-Value="_testAfterAdd" Label="추가 후 연결 테스트"
                                         Size="Size.Small" Color="Color.Primary"/>
                        }
                    </div>
                </div>
            </MudTabPanel>

            @* ── Tab 3: Import ──────────────────────────────────────────────── *@
            <MudTabPanel Text="가져오기" Icon="@Icons.Material.Filled.FileDownload">
                <div class="stack gap-3 pa-3">
                    <div>
                        <div class="typo-subtitle2 mb-1">Claude Desktop에서 가져오기</div>
                        <p class="typo-caption text-secondary mb-2">
                            Claude Desktop에 등록된 MCP 서버를 자동으로 가져옵니다.
                        </p>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.DesktopWindows"
                                   OnClick="ImportFromDesktop"
                                   Disabled="_importing">
                            @if (_importing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                     Style="width:16px;height:16px;margin-right:8px;"/>
                            }
                            Claude Desktop 설정 가져오기
                        </MudButton>
                        @if (!string.IsNullOrEmpty(_importResult))
                        {
                            <MudAlert Severity="@_importResultSeverity" Dense="true" Class="mt-2">
                                @_importResult
                            </MudAlert>
                        }
                    </div>

                    <MudDivider/>

                    <div>
                        <div class="typo-subtitle2 mb-1">JSON으로 가져오기</div>
                        <MudTextField Value="@_importJson" ValueChanged="OnImportJsonChanged" T="string"
                                      Label="MCP 설정 JSON" Variant="Variant.Outlined" Lines="6"
                                      Placeholder='{"mcpServers": {"name": {"command": "...", "args": []}}}'/>

                        @if (!string.IsNullOrWhiteSpace(_importJson) && _importPreview.Count > 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1">
                                가져올 서버: @string.Join(", ", _importPreview)
                            </MudAlert>
                        }
                        @if (!string.IsNullOrWhiteSpace(_importJson) && _importPreviewError != null)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-1">
                                JSON 오류: @_importPreviewError
                            </MudAlert>
                        }

                        <MudSelect T="string" @bind-Value="_importScope" Label="범위"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2">
                            <MudSelectItem T="string" Value="@("user")">사용자 (전역)</MudSelectItem>
                            <MudSelectItem T="string" Value="@("project")">프로젝트</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-2"
                                   OnClick="ImportFromJson"
                                   Disabled="@(string.IsNullOrWhiteSpace(_importJson) || _importPreviewError != null)">
                            JSON 가져오기
                        </MudButton>
                    </div>
                </div>
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">닫기</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private List<McpServer> _servers = [];
    private bool _loading;
    private bool _importing;
    private bool _saving;
    private bool _testingAll;
    private bool _testAfterAdd = true;
    private McpServer? _editingServer;
    private int _activeTabIndex;
    private string _formError = "";
    private string _importResult = "";
    private Severity _importResultSeverity = Severity.Success;

    // Add/Edit form
    private string _newName = "";
    private string _newTransport = "stdio";
    private string _newCommand = "";
    private readonly List<string> _argsList = [];
    private readonly HashSet<string> _argPlaceholders = [];
    private string _newUrl = "";
    private string _newScope = "user";
    private readonly List<string> _envKeys = [];
    private readonly List<string> _envValues = [];

    // Import
    private string _importJson = "";
    private string _importScope = "user";
    private List<string> _importPreview = [];
    private string? _importPreviewError;

    // Templates
    private readonly List<TemplateDefinition> _mcpTemplates =
        BuiltInTemplates.All.Where(t => t.Category == TemplateCategory.Mcp).ToList();

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _servers.Count == 0)
            await RefreshServers();
    }

    private async Task RefreshServers()
    {
        _loading = true;
        StateHasChanged();
        _servers = await McpService.ListServersAsync();
        _loading = false;
        StateHasChanged();
    }

    // ── Server List ──────────────────────────────────────────────────────────

    private async Task RemoveServer(McpServer server)
    {
        var result = await McpService.RemoveServerAsync(server.Name, server.Scope);
        if (result.Success)
        {
            Snackbar.Add($"서버 '{server.Name}'이 제거되었습니다.", Severity.Success);
            await RefreshServers();
        }
        else
        {
            Snackbar.Add($"제거 실패: {result.Error}", Severity.Error);
        }
    }

    private async Task TestConnection(McpServer server)
    {
        server.Status.ConnectionStatus = McpConnectionStatus.Checking;
        StateHasChanged();

        var status = await McpService.TestConnectionAsync(server);
        server.Status.ConnectionStatus = status.ConnectionStatus;
        server.Status.Error = status.Error;
        server.Status.LastChecked = status.LastChecked;
        StateHasChanged();

        var msg = status.ConnectionStatus == McpConnectionStatus.Reachable
            ? $"'{server.Name}' 연결 확인"
            : $"'{server.Name}' 연결 실패: {status.Error}";
        Snackbar.Add(msg, status.ConnectionStatus == McpConnectionStatus.Reachable ? Severity.Success : Severity.Warning);
    }

    private async Task TestAllConnections()
    {
        _testingAll = true;
        StateHasChanged();

        foreach (var s in _servers)
            s.Status.ConnectionStatus = McpConnectionStatus.Checking;
        StateHasChanged();

        var tasks = _servers.Select(async s =>
        {
            var status = await McpService.TestConnectionAsync(s);
            s.Status.ConnectionStatus = status.ConnectionStatus;
            s.Status.Error = status.Error;
            s.Status.LastChecked = status.LastChecked;
            StateHasChanged();
        });
        await Task.WhenAll(tasks);

        _testingAll = false;
        StateHasChanged();
    }

    // ── Quick Add (Templates) ────────────────────────────────────────────────

    private void ApplyTemplate(TemplateDefinition template)
    {
        ResetAddForm();
        _newName = template.Id.Replace("mcp-", "");
        _newTransport = template.McpType ?? "stdio";
        _newCommand = template.McpCommand ?? "";
        _newUrl = template.McpUrl ?? "";

        _argsList.Clear();
        _argPlaceholders.Clear();
        if (template.McpArgsList != null)
        {
            _argsList.AddRange(template.McpArgsList);
            if (template.McpPlaceholders != null)
                foreach (var p in template.McpPlaceholders)
                    _argPlaceholders.Add(p);
        }

        _envKeys.Clear();
        _envValues.Clear();
        if (template.McpEnv != null)
        {
            foreach (var (key, value) in template.McpEnv)
            {
                _envKeys.Add(key);
                _envValues.Add(value);
            }
        }

        _activeTabIndex = 2; // Switch to manual add tab
        StateHasChanged();
    }

    // ── Manual Add/Edit ──────────────────────────────────────────────────────

    private async Task AddServer()
    {
        _formError = "";
        _saving = true;
        StateHasChanged();

        var server = BuildServerFromForm();
        var result = await McpService.AddServerAsync(server);

        _saving = false;

        if (result.Success)
        {
            Snackbar.Add($"서버 '{_newName}'이 추가되었습니다.", Severity.Success);
            var addedName = _newName;
            ResetAddForm();
            await RefreshServers();

            if (_testAfterAdd)
            {
                var added = _servers.FirstOrDefault(s => s.Name == addedName);
                if (added != null)
                    await TestConnection(added);
            }
        }
        else
        {
            _formError = result.Error ?? "서버 추가에 실패했습니다.";
            StateHasChanged();
        }
    }

    private void StartEdit(McpServer server)
    {
        _editingServer = server;
        _newName = server.Name;
        _newTransport = server.Transport;
        _newCommand = server.Command ?? "";
        _argsList.Clear();
        _argsList.AddRange(server.Args);
        _argPlaceholders.Clear();
        _newUrl = server.Url ?? "";
        _newScope = server.Scope;

        _envKeys.Clear();
        _envValues.Clear();
        foreach (var (key, value) in server.Env)
        {
            _envKeys.Add(key);
            _envValues.Add(value);
        }

        _formError = "";
        _activeTabIndex = 2;
        StateHasChanged();
    }

    private async Task SaveEdit()
    {
        if (_editingServer == null) return;

        _formError = "";
        _saving = true;
        StateHasChanged();

        var server = BuildServerFromForm();
        var result = await McpService.UpdateServerAsync(_editingServer.Name, _editingServer.Scope, server);

        _saving = false;

        if (result.Success)
        {
            Snackbar.Add($"서버 '{_newName}'이 수정되었습니다.", Severity.Success);
            ResetAddForm();
            _activeTabIndex = 0;
            await RefreshServers();
        }
        else
        {
            _formError = result.Error ?? "서버 수정에 실패했습니다.";
            StateHasChanged();
        }
    }

    private void CancelEdit()
    {
        ResetAddForm();
        _activeTabIndex = 0;
        StateHasChanged();
    }

    private void ResetAddForm()
    {
        _editingServer = null;
        _newName = "";
        _newCommand = "";
        _argsList.Clear();
        _argPlaceholders.Clear();
        _newUrl = "";
        _newScope = "user";
        _envKeys.Clear();
        _envValues.Clear();
        _formError = "";
    }

    private McpServer BuildServerFromForm()
    {
        var env = new Dictionary<string, string>();
        for (var i = 0; i < _envKeys.Count; i++)
            if (!string.IsNullOrWhiteSpace(_envKeys[i]))
                env[_envKeys[i]] = _envValues[i];

        return new McpServer
        {
            Name = _newName.Trim(),
            Transport = _newTransport,
            Command = _newTransport == "stdio" ? _newCommand.Trim() : null,
            Args = _newTransport == "stdio" ? _argsList.ToList() : [],
            Url = _newTransport != "stdio" ? _newUrl.Trim() : null,
            Env = env,
            Scope = _newScope
        };
    }

    private bool IsFormInvalid() =>
        string.IsNullOrWhiteSpace(_newName) ||
        (_newTransport == "stdio" && string.IsNullOrWhiteSpace(_newCommand)) ||
        (_newTransport != "stdio" && string.IsNullOrWhiteSpace(_newUrl));

    private void AddArg() => _argsList.Add("");
    private void RemoveArg(int idx) { if (idx < _argsList.Count) _argsList.RemoveAt(idx); }
    private void AddEnvRow() { _envKeys.Add(""); _envValues.Add(""); }
    private void RemoveEnvRow(int idx)
    {
        if (idx < _envKeys.Count) { _envKeys.RemoveAt(idx); _envValues.RemoveAt(idx); }
    }

    // ── Import ───────────────────────────────────────────────────────────────

    private async Task ImportFromDesktop()
    {
        _importing = true;
        _importResult = "";
        StateHasChanged();

        var result = await McpService.ImportFromClaudeDesktopAsync();
        _importResultSeverity = result.Success ? Severity.Success : Severity.Error;
        _importResult = result.Success
            ? result.Error ?? "Claude Desktop 설정을 가져왔습니다."  // Error field used for detail message on success
            : result.Error ?? "가져오기에 실패했습니다.";

        if (result.Success)
            await RefreshServers();

        _importing = false;
        StateHasChanged();
    }

    private async Task ImportFromJson()
    {
        var result = await McpService.ImportFromJsonAsync(_importJson, _importScope);
        if (result.Success)
        {
            Snackbar.Add(result.Error ?? "JSON 설정을 가져왔습니다.", Severity.Success);
            _importJson = "";
            _importPreview.Clear();
            await RefreshServers();
        }
        else
        {
            Snackbar.Add($"JSON 가져오기 실패: {result.Error}", Severity.Error);
        }
    }

    // JSON import preview (called from UI via @bind)
    private void OnImportJsonChanged(string value)
    {
        _importJson = value;
        _importPreview.Clear();
        _importPreviewError = null;

        if (string.IsNullOrWhiteSpace(value)) return;

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(value);
            if (doc.RootElement.TryGetProperty("mcpServers", out var servers))
                foreach (var s in servers.EnumerateObject())
                    _importPreview.Add(s.Name);
        }
        catch (System.Text.Json.JsonException ex)
        {
            _importPreviewError = ex.Message;
        }
    }

    // ── Dialog ───────────────────────────────────────────────────────────────

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    // ── Display helpers ──────────────────────────────────────────────────────

    private static bool IsCloudServer(McpServer server) =>
        server.Transport == "sse" ||
        (!string.IsNullOrEmpty(server.Url) &&
         !server.Url.Contains("localhost") &&
         !server.Url.Contains("127.0.0.1"));

    private static string GetTransportIcon(McpServer server) =>
        server.Transport == "sse" || IsCloudServer(server)
            ? Icons.Material.Filled.Cloud
            : Icons.Material.Filled.Terminal;

    private static Color GetScopeColor(string scope) => scope switch
    {
        "project" => Color.Info,
        "local" => Color.Warning,
        _ => Color.Default
    };

    private static string GetScopeLabel(string scope) => scope switch
    {
        "project" => "프로젝트",
        "local" => "로컬",
        _ => "전역"
    };
}

