@inherits LayoutComponentBase
@inject ChatState ChatState
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="background: transparent;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       Size="Size.Small" OnClick="@ToggleDrawer" />
        <span class="app-title ml-3">Cominomi</span>
        <MudSpacer />
        <StatusBar />
        @if (ChatState.CurrentSession != null && ChatState.CurrentSession.Status != SessionStatus.Pending)
        {
            <MudTooltip Text="컨텍스트 (메모, 계획, 작업)">
                <MudIconButton Icon="@Icons.Material.Filled.Folder"
                               Color="@(_contextPanelOpen ? Color.Primary : Color.Inherit)"
                               Size="Size.Small"
                               OnClick="@(() => _contextPanelOpen = !_contextPanelOpen)" />
            </MudTooltip>
            <MudTooltip Text="변경사항 보기">
                <MudIconButton Icon="@Icons.Material.Filled.Difference"
                               Color="@(ChatState.IsDiffPanelOpen ? Color.Primary : Color.Inherit)"
                               Size="Size.Small"
                               OnClick="@(() => ChatState.ToggleDiffPanel())" />
            </MudTooltip>
        }
        <MudTooltip Text="@(_isDarkMode ? "라이트 모드" : "다크 모드")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" Size="Size.Small" OnClick="@ToggleDarkMode" />
        </MudTooltip>
        <MudTooltip Text="설정">
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit"
                           Size="Size.Small" OnClick="@OpenSettings" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="DrawerVariant.Responsive" Width="260px"
               Style="border-right: 1px solid var(--cominomi-border-subtle);">
        <SessionList />
    </MudDrawer>

    <MudMainContent Class="pa-0" Style="height: calc(100vh - 48px);">
        @Body
    </MudMainContent>

    <DiffPanel />
    <ContextPanel @bind-IsOpen="_contextPanelOpen" />
</MudLayout>

<SettingsDialog @bind-IsOpen="_settingsOpen" />
<SetupDialog @bind-IsOpen="_setupOpen" />

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private bool _settingsOpen;
    private bool _setupOpen;
    private bool _contextPanelOpen;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c3aed",
            AppbarBackground = "#f5f5f5",
            AppbarText = "#333333",
            Background = "#ffffff",
            Surface = "#f5f5f5",
            DrawerBackground = "#fafafa",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#a78bfa",
            AppbarBackground = "#1e1e2e",
            AppbarText = "#cdd6f4",
            Background = "#1e1e2e",
            Surface = "#313244",
            DrawerBackground = "#11111b",
            TextPrimary = "#cdd6f4",
            TextSecondary = "#a6adc8",
            LinesDefault = "rgba(166,173,200,0.08)",
        }
    };

    [Inject] private ISettingsService SettingsService { get; set; } = default!;
    [Inject] private IDependencyCheckService DependencyCheckService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;

        var settings = await SettingsService.LoadAsync();
        _isDarkMode = settings.Theme != "light";

        var deps = await DependencyCheckService.CheckAllAsync();
        if (deps.Any(d => !d.IsInstalled))
        {
            _setupOpen = true;
        }
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void OpenSettings() => _settingsOpen = true;

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
