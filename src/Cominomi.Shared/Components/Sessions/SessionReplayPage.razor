@using Cominomi.Shared.Models
@using Markdig
@inject ISessionReplayService ReplayService
@implements IDisposable

<div class="srp-root">
    @* ===== Left Sidebar ===== *@
    <div class="srp-sidebar">
        <div class="srp-sidebar-header">
            <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search sessions..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="false"
                          OnKeyDown="OnSearchKeyDown" Class="srp-search-field" />
        </div>

        <div class="srp-sidebar-body">
            @if (_searchMode)
            {
                <div class="srp-section-header">
                    <span class="typo-caption" style="font-weight:600;">Search Results (@_searchResults.Count)</span>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                               OnClick="ClearSearch" Style="text-transform:none; min-width:auto;">
                        Clear
                    </MudButton>
                </div>
                @foreach (var r in _searchResults)
                {
                    <div class="srp-search-item" @onclick="() => SelectSearchResult(r)">
                        <div class="typo-caption text-secondary">
                            @r.Timestamp.ToString("MM/dd HH:mm") &middot; @GetProjectName(r.ProjectPath)
                        </div>
                        <div class="typo-body2 srp-snippet">@r.Snippet</div>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Style="font-size:0.7rem;">@r.EventType</MudChip>
                    </div>
                }
                @if (_searchResults.Count == 0)
                {
                    <div class="typo-caption text-secondary" style="text-align:center; padding:24px 0;">
                        No results found
                    </div>
                }
            }
            else
            {
                @* Live sessions *@
                @if (_liveSessions.Count > 0)
                {
                    <div class="srp-section-header">
                        <span class="typo-caption" style="font-weight:600;">
                            <span class="srp-live-dot"></span> Live Sessions
                        </span>
                    </div>
                    @foreach (var live in _liveSessions)
                    {
                        <div class="srp-live-item">
                            <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small"
                                     Style="color: var(--mud-palette-success); font-size:10px;" />
                            <div style="flex:1; min-width:0;">
                                <div class="typo-body2" style="font-weight:500;">@GetProjectName(live.ProjectPath)</div>
                                <div class="typo-caption text-secondary">@(live.ModifiedSecsAgo)s ago</div>
                            </div>
                        </div>
                    }
                }

                @* Session list *@
                @if (_loading)
                {
                    <div style="display:flex; justify-content:center; padding:32px 0;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else
                {
                    @foreach (var s in _sessions)
                    {
                        <div class="@SessionItemClass(s)" @onclick="() => SelectSession(s)">
                            <div class="srp-item-top">
                                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small"
                                         Style="opacity:0.6;" />
                                <span class="typo-body2" style="font-weight:500; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                    @GetProjectName(s.ProjectPath)
                                </span>
                                <span class="typo-caption text-secondary" style="white-space:nowrap;">
                                    @FormatTimestamp(s.FirstTimestamp)
                                </span>
                            </div>
                            <div class="typo-caption srp-first-msg">
                                @(s.FirstMessage ?? "(empty session)")
                            </div>
                            @if (GetSessionTags(s.Id).Count > 0)
                            {
                                <div class="srp-tags-row">
                                    @foreach (var tag in GetSessionTags(s.Id))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                 Color="Color.Primary" Style="font-size:0.65rem; height:20px;">
                                            @tag
                                        </MudChip>
                                    }
                                </div>
                            }
                            <div class="srp-item-stats">
                                <span>@s.MessageCount msgs</span>
                                <span>@s.ToolCallCount tools</span>
                                <span>@s.EntryCount events</span>
                                @if (s.Duration.HasValue)
                                {
                                    <span>@FormatDuration(s.Duration.Value)</span>
                                }
                            </div>
                        </div>
                    }

                    @if (_sessions.Count == 0)
                    {
                        <div class="typo-caption text-secondary" style="text-align:center; padding:32px 0;">
                            No session history found
                        </div>
                    }

                    @if (_hasMoreSessions)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="LoadMoreSessions"
                                   FullWidth="true" Style="text-transform:none; margin-top:4px;"
                                   Disabled="_loadingMore">
                            @if (_loadingMore)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            }
                            Load more (@_sessions.Count/@_totalSessions)
                        </MudButton>
                    }
                }
            }
        </div>
    </div>

    @* ===== Right Area ===== *@
    <div class="srp-main">
        @if (_selected == null)
        {
            <div class="srp-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.History" Style="font-size:64px; opacity:0.3;" />
                <div class="typo-body1 text-secondary" style="margin-top:12px;">Select a session to replay</div>
            </div>
        }
        else
        {
            @* Session Header Bar *@
            <div class="srp-header">
                <div class="srp-header-left">
                    <div class="typo-body1" style="font-weight:600;">
                        @GetProjectName(_selected.ProjectPath)
                        <span class="typo-caption text-secondary" style="margin-left:8px;">
                            @FormatTimestamp(_selected.FirstTimestamp)
                        </span>
                    </div>
                    <div class="typo-caption text-secondary srp-first-msg" style="margin-top:2px;">
                        @(_selected.FirstMessage ?? "(empty session)")
                    </div>
                </div>
                <div class="srp-header-right">
                    <div class="srp-header-stats">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                            <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Small" Class="mr-1" />
                            @_selected.MessageCount
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Class="mr-1" />
                            @_selected.ToolCallCount
                        </MudChip>
                        @if (_selected.Duration.HasValue)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                                <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Class="mr-1" />
                                @FormatDuration(_selected.Duration.Value)
                            </MudChip>
                        }
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                            @_selected.EntryCount events
                        </MudChip>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small"
                                   Title="Export Markdown" OnClick="ExportMarkdown" />
                    <MudIconButton Icon="@Icons.Material.Filled.Label" Size="Size.Small"
                                   Title="Tags" Color="@(_showTagEditor ? Color.Primary : Color.Default)"
                                   OnClick="() => _showTagEditor = !_showTagEditor" />
                    @if (_replayActive)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                   OnClick="StopReplay" Style="text-transform:none;">
                            <MudIcon Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Class="mr-1" />
                            Stop (@_replayIndex/@_events.Count)
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   OnClick="StartReplay" Style="text-transform:none;"
                                   Disabled="@(_events.Count == 0)">
                            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Class="mr-1" />
                            Replay
                        </MudButton>
                    }
                </div>
            </div>

            @* Tag Editor Bar *@
            @if (_showTagEditor)
            {
                <div class="srp-tag-editor">
                    <div class="srp-tag-chips">
                        @foreach (var tag in GetSessionTags(_selected.Id))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                     OnClose="() => RemoveTag(tag)">
                                @tag
                            </MudChip>
                        }
                    </div>
                    <div class="srp-tag-input-row">
                        <MudTextField T="string" @bind-Value="_newTag" Placeholder="Add tag..."
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      OnKeyDown="OnTagKeyDown" Style="max-width:200px;" />
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => AddPresetTag("bug-fix"))"
                                   Style="text-transform:none;">bug-fix</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => AddPresetTag("feature"))"
                                   Style="text-transform:none;">feature</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => AddPresetTag("refactor"))"
                                   Style="text-transform:none;">refactor</MudButton>
                    </div>
                </div>
            }

            @* Event Stream *@
            <div class="srp-events">
                @if (_loadingEvents)
                {
                    <div style="display:flex; justify-content:center; padding:32px 0;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else
                {
                    var visibleEvents = _replayActive ? _events.Take(_replayIndex).ToList() : _events;
                    @foreach (var evt in visibleEvents)
                    {
                        @if (evt.Type is "user" or "human")
                        {
                            <div class="srp-event-row">
                                <div class="srp-avatar srp-avatar-user">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small"
                                             Style="color:white;" />
                                </div>
                                <div class="srp-event-body" style="flex:1; min-width:0;">
                                    <div class="srp-event-meta">
                                        <span style="font-weight:600;">You</span>
                                        @if (evt.Timestamp.HasValue)
                                        {
                                            <span class="text-secondary"> &middot; @evt.Timestamp.Value.ToString("HH:mm:ss")</span>
                                        }
                                    </div>
                                    <div class="srp-card-user">
                                        <div class="typo-body2" style="white-space:pre-wrap; word-break:break-word;">@evt.Content</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (evt.Type == "assistant")
                        {
                            <div class="srp-event-row">
                                <div class="srp-avatar srp-avatar-assistant">
                                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small"
                                             Style="color:white;" />
                                </div>
                                <div class="srp-event-body" style="flex:1; min-width:0;">
                                    <div class="srp-event-meta">
                                        <span style="font-weight:600;">Claude</span>
                                        @if (evt.Timestamp.HasValue)
                                        {
                                            <span class="text-secondary"> &middot; @evt.Timestamp.Value.ToString("HH:mm:ss")</span>
                                        }
                                    </div>
                                    @if (evt.ToolCalls?.Count > 0)
                                    {
                                        <div class="srp-tool-calls">
                                            @foreach (var tc in evt.ToolCalls)
                                            {
                                                <div class="srp-tool-card">
                                                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small"
                                                             Style="opacity:0.7;" />
                                                    <div style="flex:1; min-width:0;">
                                                        <div class="typo-body2" style="font-weight:500;">@tc.Name</div>
                                                        <div class="typo-caption text-secondary srp-snippet">@tc.InputPreview</div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(evt.Content))
                                    {
                                        @if (evt.Content.Length > 300 && !IsExpanded(evt))
                                        {
                                            <div class="srp-card-assistant">
                                                <div class="srp-md-content">@RenderMarkdown(evt.Content[..300] + "...")</div>
                                                <MudButton Size="Size.Small" Variant="Variant.Text"
                                                           OnClick="() => ToggleExpand(evt)"
                                                           Style="text-transform:none; padding:0; margin-top:4px;">
                                                    Show more
                                                </MudButton>
                                            </div>
                                        }
                                        else if (evt.Content.Length > 300)
                                        {
                                            <div class="srp-card-assistant">
                                                <div class="srp-md-content">@RenderMarkdown(evt.Content)</div>
                                                <MudButton Size="Size.Small" Variant="Variant.Text"
                                                           OnClick="() => ToggleExpand(evt)"
                                                           Style="text-transform:none; padding:0; margin-top:4px;">
                                                    Show less
                                                </MudButton>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="srp-card-assistant">
                                                <div class="srp-md-content">@RenderMarkdown(evt.Content)</div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                        else if (evt.Type == "tool_use")
                        {
                            <div class="srp-event-row">
                                <div class="srp-avatar srp-avatar-tool">
                                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small"
                                             Style="color:white;" />
                                </div>
                                <div class="srp-event-body" style="flex:1; min-width:0;">
                                    <div class="srp-event-meta">
                                        <span style="font-weight:600;">@(evt.ToolName ?? "Tool")</span>
                                        @if (evt.Timestamp.HasValue)
                                        {
                                            <span class="text-secondary"> &middot; @evt.Timestamp.Value.ToString("HH:mm:ss")</span>
                                        }
                                    </div>
                                    <div class="srp-tool-card" style="margin-top:4px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small"
                                                 Style="opacity:0.7;" />
                                        <div style="flex:1; min-width:0;">
                                            <div class="typo-body2" style="font-weight:500;">@(evt.ToolName ?? "Tool")</div>
                                            @if (!string.IsNullOrWhiteSpace(evt.Content))
                                            {
                                                <div class="typo-caption text-secondary srp-snippet">@evt.Content</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (evt.Type == "tool_result")
                        {
                            <div class="srp-event-row">
                                <div class="srp-avatar srp-avatar-result">
                                    <MudIcon Icon="@Icons.Material.Filled.Output" Size="Size.Small"
                                             Style="color:white;" />
                                </div>
                                <div class="srp-event-body" style="flex:1; min-width:0;">
                                    <div class="srp-result-header" @onclick="() => ToggleResult(evt)">
                                        <MudIcon Icon="@(IsResultExpanded(evt) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                 Size="Size.Small" />
                                        <span class="typo-body2">Tool output (@(evt.Content?.Length ?? 0) chars)</span>
                                        @if (evt.Timestamp.HasValue)
                                        {
                                            <span class="typo-caption text-secondary" style="margin-left:auto;">
                                                @evt.Timestamp.Value.ToString("HH:mm:ss")
                                            </span>
                                        }
                                    </div>
                                    @if (IsResultExpanded(evt))
                                    {
                                        <pre class="srp-result-content">@evt.Content</pre>
                                    }
                                </div>
                            </div>
                        }
                    }

                    @if (_hasMoreEvents && !_replayActive)
                    {
                        <div style="display:flex; justify-content:center; padding:12px 0;">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="LoadMoreEvents"
                                       Style="text-transform:none;" Disabled="_loadingMoreEvents">
                                @if (_loadingMoreEvents)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                                }
                                Load more events (@_events.Count/@_selected.EntryCount)
                            </MudButton>
                        </div>
                    }

                    @if (_events.Count == 0 && !_loadingEvents)
                    {
                        <div class="typo-caption text-secondary" style="text-align:center; padding:32px 0;">
                            No events in this session
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    // === State: sessions ===
    private List<SessionReplaySummary> _sessions = [];
    private int _totalSessions;
    private bool _hasMoreSessions;
    private bool _loading = true;
    private bool _loadingMore;
    private const int SessionPageSize = 10;

    // === State: selected session & events ===
    private SessionReplaySummary? _selected;
    private List<SessionReplayEvent> _events = [];
    private bool _loadingEvents;
    private bool _hasMoreEvents;
    private bool _loadingMoreEvents;
    private int _eventPage;
    private const int EventPageSize = 100;

    // === State: search ===
    private string _searchText = "";
    private bool _searchMode;
    private List<SessionSearchResult> _searchResults = [];

    // === State: live sessions ===
    private List<LiveSessionInfo> _liveSessions = [];
    private System.Threading.Timer? _liveTimer;

    // === State: tags ===
    private SessionTagStore _tagStore = new();
    private bool _showTagEditor;
    private string _newTag = "";

    // === State: replay ===
    private bool _replayActive;
    private int _replayIndex;
    private System.Threading.Timer? _replayTimer;

    // === State: expand/collapse tracking ===
    private readonly HashSet<SessionReplayEvent> _expandedEvents = [];
    private readonly HashSet<SessionReplayEvent> _expandedResults = [];

    protected override async Task OnInitializedAsync()
    {
        var result = await ReplayService.ListSessionsPagedAsync(SessionPageSize, 0);
        _sessions = result.Sessions;
        _totalSessions = result.Total;
        _hasMoreSessions = result.HasMore;

        _tagStore = await ReplayService.GetTagsAsync();

        _liveSessions = await ReplayService.DetectLiveSessionsAsync();

        _loading = false;

        _liveTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                var live = await ReplayService.DetectLiveSessionsAsync();
                await InvokeAsync(() =>
                {
                    _liveSessions = live;
                    StateHasChanged();
                });
            }
            catch { /* ignore timer errors */ }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    // === Session list ===
    private async Task LoadMoreSessions()
    {
        _loadingMore = true;
        var result = await ReplayService.ListSessionsPagedAsync(SessionPageSize, _sessions.Count);
        _sessions.AddRange(result.Sessions);
        _totalSessions = result.Total;
        _hasMoreSessions = result.HasMore;
        _loadingMore = false;
    }

    private async Task SelectSession(SessionReplaySummary session)
    {
        StopReplayInternal();
        _selected = session;
        _loadingEvents = true;
        _eventPage = 0;
        _events = [];
        _expandedEvents.Clear();
        _expandedResults.Clear();
        StateHasChanged();

        _events = await ReplayService.LoadEventsAsync(session.FilePath, 0, EventPageSize);
        _hasMoreEvents = _events.Count == EventPageSize;
        _loadingEvents = false;
    }

    private async Task LoadMoreEvents()
    {
        if (_selected == null) return;
        _loadingMoreEvents = true;
        _eventPage++;
        var more = await ReplayService.LoadEventsAsync(_selected.FilePath, _eventPage * EventPageSize, EventPageSize);
        _events.AddRange(more);
        _hasMoreEvents = more.Count == EventPageSize;
        _loadingMoreEvents = false;
    }

    // === Search ===
    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchText))
        {
            _searchResults = await ReplayService.SearchSessionsAsync(_searchText);
            _searchMode = true;
        }
    }

    private void ClearSearch()
    {
        _searchMode = false;
        _searchText = "";
        _searchResults.Clear();
    }

    private async Task SelectSearchResult(SessionSearchResult result)
    {
        var match = _sessions.FirstOrDefault(s => s.Id == result.SessionId);
        if (match != null)
        {
            await SelectSession(match);
        }
        else
        {
            // Load the session via full list lookup
            var all = await ReplayService.ListSessionsAsync();
            var found = all.FirstOrDefault(s => s.Id == result.SessionId);
            if (found != null) await SelectSession(found);
        }
    }

    // === Tags ===
    private List<string> GetSessionTags(string sessionId) =>
        _tagStore.Tags.TryGetValue(sessionId, out var tags) ? tags : [];

    private async Task RemoveTag(string tag)
    {
        if (_selected == null) return;
        var tags = GetSessionTags(_selected.Id).Where(t => t != tag).ToList();
        await ReplayService.SetTagAsync(_selected.Id, tags);
        _tagStore.Tags[_selected.Id] = tags;
    }

    private async Task AddTag(string tag)
    {
        if (_selected == null || string.IsNullOrWhiteSpace(tag)) return;
        var tags = GetSessionTags(_selected.Id).ToList();
        if (!tags.Contains(tag, StringComparer.OrdinalIgnoreCase))
        {
            tags.Add(tag);
            await ReplayService.SetTagAsync(_selected.Id, tags);
            _tagStore.Tags[_selected.Id] = tags;
        }
    }

    private async Task AddPresetTag(string tag) => await AddTag(tag);

    private async Task OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newTag))
        {
            await AddTag(_newTag.Trim());
            _newTag = "";
        }
    }

    // === Export ===
    private async Task ExportMarkdown()
    {
        if (_selected == null) return;
        await ReplayService.ExportMarkdownAsync(_selected.FilePath);
    }

    // === Replay ===
    private void StartReplay()
    {
        if (_events.Count == 0) return;
        _replayActive = true;
        _replayIndex = 0;
        _replayTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                if (!_replayActive) return;
                _replayIndex++;
                if (_replayIndex >= _events.Count)
                {
                    StopReplayInternal();
                }
                StateHasChanged();
            });
        }, null, TimeSpan.FromMilliseconds(300), TimeSpan.FromMilliseconds(300));
    }

    private void StopReplay()
    {
        StopReplayInternal();
    }

    private void StopReplayInternal()
    {
        _replayActive = false;
        _replayTimer?.Dispose();
        _replayTimer = null;
    }

    // === Expand/collapse ===
    private bool IsExpanded(SessionReplayEvent evt) => _expandedEvents.Contains(evt);
    private void ToggleExpand(SessionReplayEvent evt)
    {
        if (!_expandedEvents.Remove(evt)) _expandedEvents.Add(evt);
    }

    private bool IsResultExpanded(SessionReplayEvent evt) => _expandedResults.Contains(evt);
    private void ToggleResult(SessionReplayEvent evt)
    {
        if (!_expandedResults.Remove(evt)) _expandedResults.Add(evt);
    }

    // === Markdown rendering ===
    private static readonly MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static MarkupString RenderMarkdown(string md) =>
        new(Markdig.Markdown.ToHtml(md, _mdPipeline));

    // === Helpers ===
    private static string GetProjectName(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "Unknown Project";
        var parts = path.Split('/', '\\');
        return parts.Length > 0 ? parts[^1] : path;
    }

    private static string FormatTimestamp(DateTime? dt) =>
        dt?.ToString("MM/dd HH:mm") ?? "";

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m";
        if (ts.TotalMinutes >= 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }

    private string SessionItemClass(SessionReplaySummary s) =>
        $"srp-session-item {(_selected?.Id == s.Id ? "active" : "")}";

    public void Dispose()
    {
        _liveTimer?.Dispose();
        _replayTimer?.Dispose();
    }
}

<style>
    .srp-root {
        display: flex;
        height: calc(100vh - 64px);
        overflow: hidden;
    }

    /* === Sidebar === */
    .srp-sidebar {
