@inject ISessionService SessionService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">풀 리퀘스트 생성</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_title" Label="제목" Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
            <MudTextField @bind-Value="_body" Label="설명" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Lines="4" />
            <MudSelect T="string" @bind-Value="_mergeMethod" Label="병합 방식"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                <MudSelectItem T="string" Value="@("squash")">스쿼시 후 병합</MudSelectItem>
                <MudSelectItem T="string" Value="@("merge")">병합 커밋 생성</MudSelectItem>
                <MudSelectItem T="string" Value="@("rebase")">리베이스 후 병합</MudSelectItem>
            </MudSelect>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_isCreating">취소</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Create" Disabled="_isCreating">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width: 16px; height: 16px;" Class="mr-2" />
            }
            PR 생성
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string SessionId { get; set; } = "";

    [Parameter]
    public string DefaultTitle { get; set; } = "";

    private string _title = "";
    private string _body = "";
    private string _mergeMethod = "squash";
    private string? _error;
    private bool _isCreating;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_title))
            _title = DefaultTitle;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            _error = "제목을 입력해주세요.";
            return;
        }

        _isCreating = true;
        _error = null;
        StateHasChanged();

        try
        {
            var session = await SessionService.CreatePrAsync(SessionId, _title.Trim(), _body.Trim());
            if (!string.IsNullOrEmpty(session.ErrorMessage))
            {
                _error = session.ErrorMessage;
            }
            else
            {
                MudDialog.Close(DialogResult.Ok(_mergeMethod));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isCreating = false;
            StateHasChanged();
        }
    }
}
