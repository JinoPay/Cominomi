@using Cominomi.Shared.Models
@inject ITerminalService TerminalService
@inject IChatState ChatState
@inject IThemeService ThemeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="terminal-panel">
    <div class="terminal-panel-toolbar">
        <span class="embedded-diff-tab active">Terminal</span>
        <div style="flex:1"></div>
        @if (_isRunning)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           OnClick="RestartTerminal" Title="Restart" Class="terminal-btn" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="StopTerminal" Title="Kill" Class="terminal-btn" />
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small"
                           OnClick="StartTerminal" Title="Start" Class="terminal-btn" />
        }
    </div>

    @* Each session gets its own xterm container, shown/hidden via CSS *@
    <div class="terminal-instances">
        @foreach (var kv in _instances)
        {
            <div id="@kv.Value" class="terminal-container"
                 style="@(kv.Key == _currentSessionKey ? "" : "display:none")"></div>
        }
    </div>
</div>

@code {
    private readonly Dictionary<string, string> _instances = new(); // sessionKey → elementId
    private readonly HashSet<string> _exitedSessions = new();
    private DotNetObjectReference<TerminalPanel>? _dotNetRef;
    private string? _currentSessionKey;
    private bool _isRunning;
    private bool _initialized;

    protected override void OnInitialized()
    {
        TerminalService.OnOutput += HandleOutput;
        TerminalService.OnExited += HandleExited;
        ChatState.OnChange += HandleStateChanged;
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _initialized = true;
            await TryStartForCurrentSession();
        }

        // Initialize any newly added terminal containers
        await InitPendingTerminals();
    }

    [JSInvokable]
    public async Task OnTerminalInput(string data)
    {
        if (_currentSessionKey != null)
            await TerminalService.WriteAsync(_currentSessionKey, data);
    }

    /// <summary>Called when the parent panel is resized — re-fit all visible xterm instances.</summary>
    public async Task FitAsync()
    {
        if (!_initialized || _currentSessionKey == null) return;
        if (_instances.TryGetValue(_currentSessionKey, out var elId))
        {
            try { await JS.InvokeVoidAsync("terminalFit", elId); }
            catch { }
        }
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(async () =>
        {
            // Update theme for all xterm instances so switching back shows correct colors
            foreach (var elId in _instances.Values)
            {
                try { await JS.InvokeVoidAsync("terminalUpdateTheme", elId); }
                catch { }
            }
        });
    }

    private void HandleOutput(string sessionKey, string data)
    {
        // Buffer output to the correct terminal, even if not currently visible
        if (!_instances.TryGetValue(sessionKey, out var elId)) return;
        _ = InvokeAsync(async () =>
        {
            try { await JS.InvokeVoidAsync("terminalWrite", elId, data); }
            catch { }
        });
    }

    private void HandleExited(string sessionKey, int exitCode)
    {
        _ = InvokeAsync(() =>
        {
            _exitedSessions.Add(sessionKey);
            if (sessionKey == _currentSessionKey)
            {
                _isRunning = false;
                StateHasChanged();
            }
        });
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await TryStartForCurrentSession();
            StateHasChanged();
        });
    }

    private async Task TryStartForCurrentSession()
    {
        var session = ChatState.CurrentSession;
        if (session == null || session.Status == SessionStatus.Pending) return;

        var key = session.Id;
        var sessionChanged = key != _currentSessionKey;
        _currentSessionKey = key;

        // Ensure this session has an xterm container
        if (!_instances.ContainsKey(key))
        {
            _instances[key] = $"term-{Guid.NewGuid():N}";
            StateHasChanged();
            await Task.Yield(); // Let Blazor create the DOM element
            await InitPendingTerminals(); // Initialize xterm.js BEFORE process starts
        }

        if (TerminalService.IsRunning(key))
        {
            _isRunning = true;
            // Fit the terminal after switching
            if (sessionChanged && _initialized && _instances.TryGetValue(key, out var elId))
            {
                try
                {
                    await Task.Yield(); // Let Blazor update DOM visibility
                    await JS.InvokeVoidAsync("terminalFit", elId);
                }
                catch { }
            }
            return;
        }

        // If this session's process has exited, just update the button state
        if (_exitedSessions.Contains(key))
        {
            _isRunning = false;
            return;
        }

        var workDir = !string.IsNullOrEmpty(session.Git.WorktreePath)
            ? session.Git.WorktreePath
            : Environment.CurrentDirectory;

        _exitedSessions.Remove(key);
        await TerminalService.StartAsync(key, workDir);
        _isRunning = TerminalService.IsRunning(key);

        // Re-fit after process starts so the prompt isn't at the bottom of an oversized terminal
        if (_instances.TryGetValue(key, out var fitElId))
        {
            try
            {
                await Task.Yield();
                await JS.InvokeVoidAsync("terminalFit", fitElId);
            }
            catch { }
        }
    }

    /// <summary>Initialize xterm.js for any containers that don't have a terminal yet.</summary>
    private async Task InitPendingTerminals()
    {
        if (!_initialized || _dotNetRef == null) return;

        foreach (var (sessionKey, elId) in _instances)
        {
            // Check if already initialized by checking JS side
            try
            {
                var exists = await JS.InvokeAsync<bool>("eval", $"!!window._terminals['{elId}']");
                if (!exists)
                {
                    await JS.InvokeVoidAsync("initTerminal", elId, _dotNetRef);
                }
            }
            catch { }
        }
    }

    private async Task StartTerminal()
    {
        // Resolve session key from current session if not yet set
        var session = ChatState.CurrentSession;
        if (session == null) return;

        var key = session.Id;
        _currentSessionKey = key;

        // Ensure xterm container exists for this session
        if (!_instances.ContainsKey(key))
        {
            _instances[key] = $"term-{Guid.NewGuid():N}";
            StateHasChanged();
            await Task.Yield(); // Let Blazor create the DOM element
            await InitPendingTerminals();
        }

        // Clear existing terminal display
        if (_instances.TryGetValue(key, out var elId))
        {
            try { await JS.InvokeVoidAsync("terminalClear", elId); }
            catch { }
        }

        var workDir = !string.IsNullOrEmpty(session.Git.WorktreePath)
            ? session.Git.WorktreePath
            : Environment.CurrentDirectory;

        _exitedSessions.Remove(key);
        await TerminalService.StartAsync(key, workDir);
        _isRunning = TerminalService.IsRunning(key);
        StateHasChanged();

        // Re-fit after process starts
        if (_instances.TryGetValue(key, out var fitElId))
        {
            try
            {
                await Task.Yield();
                await JS.InvokeVoidAsync("terminalFit", fitElId);
            }
            catch { }
        }
    }

    private async Task RestartTerminal()
    {
        if (_currentSessionKey == null) return;
        await TerminalService.StopAsync(_currentSessionKey);
        await StartTerminal();
    }

    private async Task StopTerminal()
    {
        if (_currentSessionKey == null) return;
        await TerminalService.StopAsync(_currentSessionKey);
        _isRunning = false;
    }

    public async ValueTask DisposeAsync()
    {
        TerminalService.OnOutput -= HandleOutput;
        TerminalService.OnExited -= HandleExited;
        ChatState.OnChange -= HandleStateChanged;
        ThemeService.OnThemeChanged -= HandleThemeChanged;

        foreach (var elId in _instances.Values)
        {
            try { await JS.InvokeVoidAsync("disposeTerminal", elId); }
            catch { }
        }
        _dotNetRef?.Dispose();
    }
}
