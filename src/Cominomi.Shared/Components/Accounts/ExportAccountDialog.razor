@inject IClaudeAccountService AccountService
@inject ISaveFilePickerService SaveFilePicker
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FileUpload" Color="Color.Primary"/>
            <span class="typo-subtitle1">계정 내보내기</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="stack gap-3" style="min-width: 340px;">

            @* 계정 정보 확인 *@
            <div class="d-flex align-center gap-2 pa-2"
                 style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                <MudAvatar Style="@($"background:{AvatarColor()};color:#fff;font-weight:700;font-size:14px;width:34px;height:34px;")" >
                    @(string.IsNullOrEmpty(Account.EmailAddress) ? "?" : Account.EmailAddress[0].ToString().ToUpper())
                </MudAvatar>
                <div>
                    <div class="typo-body2" style="font-weight:600;">@Account.ProfileName</div>
                    <div class="typo-caption text-secondary">@Account.EmailAddress</div>
                </div>
            </div>

            <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.Security">
                이 파일에는 OAuth 인증 토큰이 포함됩니다. 전송 후 즉시 삭제하거나 안전한 곳에 보관하세요.
            </MudAlert>

            <MudTextField @bind-Value="_password" Label="비밀번호" InputType="InputType.Password"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          HelperText="파일을 암호화할 비밀번호를 설정하세요."
                          Immediate="true" AutoFocus="true"
                          @onkeydown="OnKeyDown"/>

            <MudTextField @bind-Value="_passwordConfirm" Label="비밀번호 확인" InputType="InputType.Password"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Error="@(!string.IsNullOrEmpty(_passwordConfirm) && _password != _passwordConfirm)"
                          ErrorText="비밀번호가 일치하지 않습니다."
                          Immediate="true"
                          @onkeydown="OnKeyDown"/>

            @if (_errorMessage != null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Disabled="_exporting">취소</MudButton>
        <MudButton OnClick="Export" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!CanExport || _exporting)"
                   StartIcon="@Icons.Material.Filled.FileUpload">
            @if (_exporting)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="margin-right: 4px;"/>
            }
            내보내기
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public ClaudeAccount Account { get; set; } = null!;

    private string _password = "";
    private string _passwordConfirm = "";
    private bool _exporting;
    private string? _errorMessage;

    private bool CanExport => !string.IsNullOrWhiteSpace(_password)
                           && _password == _passwordConfirm;

    private async Task Export()
    {
        if (!CanExport) return;

        _exporting = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var envelope = await AccountService.PrepareExportAsync(Account.Id);

            var json = System.Text.Json.JsonSerializer.Serialize(envelope, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true,
                PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
            });
            var encrypted = AccountExportCrypto.Encrypt(json, _password);

            var defaultName = $"{Account.ProfileName.Replace(" ", "_")}.cominomi-account";

            var savePath = await SaveFilePicker.PickSaveFileAsync(
                "계정 내보내기",
                defaultName,
                "Cominomi Account",
                "cominomi-account");

            if (string.IsNullOrEmpty(savePath))
            {
                // 파일 다이얼로그 취소 또는 실패 → 다운로드 폴더에 자동 저장
                var downloads = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
                savePath = Path.Combine(downloads, "Downloads", defaultName);
                if (!Directory.Exists(Path.GetDirectoryName(savePath)))
                    savePath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), defaultName);

                await File.WriteAllBytesAsync(savePath, encrypted);
                Snackbar.Add($"저장 위치: {savePath}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
                return;
            }

            if (!savePath.EndsWith(".cominomi-account", StringComparison.OrdinalIgnoreCase))
                savePath += ".cominomi-account";

            await File.WriteAllBytesAsync(savePath, encrypted);
            Snackbar.Add($"'{Account.ProfileName}' 계정을 내보냈습니다.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _exporting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Export();
    }

    private string AvatarColor()
    {
        var colors = new[] { "#7c6cf6", "#22c55e", "#3b82f6", "#f97316", "#ec4899", "#06b6d4", "#a855f7" };
        return colors[Math.Abs(Account.Id.GetHashCode()) % colors.Length];
    }
}
