@inject IClaudeAccountService AccountService
@inject IClaudeCredentialService CredentialService
@inject ISaveFilePickerService SaveFilePicker
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FileDownload" Color="Color.Primary"/>
            <span class="typo-subtitle1">계정 가져오기</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="stack gap-3" style="min-width: 340px;">

            @* ── 현재 계정 미백업 경고 ── *@
            @if (_showUnbackedWarning)
            {
                <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-warning); border-radius: 8px; padding: 12px;">
                    <div class="d-flex align-start gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Style="flex-shrink:0;margin-top:1px;"/>
                        <div class="stack gap-2" style="flex:1;">
                            <div class="typo-body2" style="font-weight:600;">현재 계정이 등록되어 있지 않습니다</div>
                            @if (!string.IsNullOrEmpty(_currentEmail))
                            {
                                <div class="typo-caption text-secondary">
                                    현재 로그인: <strong>@_currentEmail</strong>
                                </div>
                            }
                            <div class="typo-caption text-secondary">
                                가져온 계정으로 전환하면 현재 인증 정보가 덮어씌워질 수 있습니다.
                                먼저 현재 계정을 등록해 두는 것을 권장합니다.
                            </div>
                            <div class="d-flex align-center gap-2 mt-1">
                                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.PersonAdd"
                                           OnClick="RegisterCurrentFirst"
                                           Disabled="_registering"
                                           Style="text-transform:none;font-size:12px;">
                                    @if (_registering)
                                    {
                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="margin-right:4px;"/>
                                    }
                                    현재 계정 등록
                                </MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small"
                                           OnClick="DismissWarning"
                                           Style="text-transform:none;font-size:12px;color:var(--mud-palette-text-secondary);">
                                    무시하고 계속
                                </MudButton>
                            </div>
                        </div>
                    </div>
                </MudPaper>
            }

            @* ── 파일 선택 ── *@
            <div class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.FolderOpen"
                           OnClick="PickFile" Style="text-transform: none; flex-shrink: 0;">
                    파일 선택
                </MudButton>
                <span class="typo-caption text-secondary"
                      style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    @(_filePath == null ? ".cominomi-account 파일을 선택하세요" : Path.GetFileName(_filePath))
                </span>
            </div>

            @if (_filePath != null)
            {
                @* ── 비밀번호 ── *@
                <MudTextField @bind-Value="_password" Label="비밀번호" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              HelperText="내보낼 때 설정한 비밀번호를 입력하세요."
                              Immediate="true" AutoFocus="true"
                              Error="@_wrongPassword"
                              ErrorText="잘못된 비밀번호입니다."
                              @onkeydown="OnKeyDown"/>

                @* ── 복호화 후 미리보기 ── *@
                @if (_preview != null)
                {
                    <div class="d-flex align-center gap-2 pa-2"
                         style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Color="Color.Success"/>
                        <div style="flex:1;min-width:0;">
                            <div class="typo-caption text-secondary">가져올 계정</div>
                            <div class="typo-body2" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                @_preview.Account.EmailAddress
                            </div>
                        </div>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                                 Style="height:20px;flex-shrink:0;">@_preview.SourcePlatform</MudChip>
                    </div>

                    @if (_isDuplicate)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            동일한 계정이 이미 등록되어 있습니다. 계속하면 별도의 항목으로 추가됩니다.
                        </MudAlert>
                    }

                    <MudTextField @bind-Value="_profileName" Label="프로필 이름"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="예: 개인 (맥), 회사 (윈도우)..."
                                  Immediate="true"
                                  @onkeydown="OnKeyDown"/>
                }
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Disabled="_importing">취소</MudButton>
        @if (_filePath != null && _preview == null)
        {
            <MudButton OnClick="Decrypt" Variant="Variant.Outlined" Color="Color.Primary"
                       Disabled="@(string.IsNullOrWhiteSpace(_password) || _importing)"
                       StartIcon="@Icons.Material.Filled.LockOpen">
                복호화
            </MudButton>
        }
        @if (_preview != null)
        {
            <MudButton OnClick="Import" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(!CanImport || _importing)"
                       StartIcon="@Icons.Material.Filled.PersonAdd">
                @if (_importing)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="margin-right: 4px;"/>
                }
                가져오기
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string? _filePath;
    private string _password = "";
    private string _profileName = "";
    private bool _wrongPassword;
    private bool _isDuplicate;
    private bool _importing;
    private bool _registering;
    private bool _showUnbackedWarning;
    private string? _currentEmail;
    private AccountExportEnvelope? _preview;

    private bool CanImport => _preview != null && !string.IsNullOrWhiteSpace(_profileName);

    protected override async Task OnInitializedAsync()
    {
        var accounts = await AccountService.GetAccountsAsync();
        if (accounts.Count == 0)
        {
            // 등록된 계정이 없음 → 현재 CLI 로그인 상태 감지
            try
            {
                var configJson = await CredentialService.ReadCurrentConfigAsync();
                var credJson = await CredentialService.ReadCurrentCredentialsAsync();
                _currentEmail = CredentialService.ExtractEmail(configJson, credJson);
                // CLI에 로그인된 상태이면 경고 표시
                _showUnbackedWarning = !string.IsNullOrEmpty(_currentEmail) || configJson != null;
            }
            catch
            {
                // CLI 상태 감지 실패 → 경고 생략
            }
        }
    }

    private async Task RegisterCurrentFirst()
    {
        _registering = true;
        StateHasChanged();
        try
        {
            var profileName = string.IsNullOrEmpty(_currentEmail) ? "기본 계정" : _currentEmail.Split('@')[0];
            await AccountService.RegisterCurrentAsync(profileName);
            _showUnbackedWarning = false;
            Snackbar.Add($"현재 계정을 '{profileName}'으로 등록했습니다.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"현재 계정 등록 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            _registering = false;
        }
    }

    private void DismissWarning() => _showUnbackedWarning = false;

    private async Task PickFile()
    {
        var path = await SaveFilePicker.PickOpenFileAsync(
            "계정 파일 선택",
            "Cominomi Account",
            "cominomi-account");

        if (path == null) return;

        _filePath = path;
        _preview = null;
        _wrongPassword = false;
        _password = "";
        _profileName = "";
    }

    private async Task Decrypt()
    {
        if (_filePath == null || string.IsNullOrWhiteSpace(_password)) return;

        _importing = true;
        StateHasChanged();
        try
        {
            var bytes = await File.ReadAllBytesAsync(_filePath);
            string json;
            try
            {
                json = AccountExportCrypto.Decrypt(bytes, _password);
                _wrongPassword = false;
            }
            catch (System.Security.Cryptography.CryptographicException)
            {
                _wrongPassword = true;
                return;
            }
            catch (InvalidDataException ex)
            {
                Snackbar.Add($"파일이 손상되었거나 유효하지 않습니다: {ex.Message}", Severity.Error);
                return;
            }
            catch (NotSupportedException ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
                return;
            }

            _preview = System.Text.Json.JsonSerializer.Deserialize<AccountExportEnvelope>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (_preview == null)
            {
                Snackbar.Add("파일을 파싱할 수 없습니다.", Severity.Error);
                return;
            }

            _profileName = _preview.Account.ProfileName;

            var accounts = await AccountService.GetAccountsAsync();
            _isDuplicate = accounts.Any(a =>
                a.AccountUuid == _preview.Account.AccountUuid ||
                a.EmailAddress == _preview.Account.EmailAddress);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"파일 읽기 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task Import()
    {
        if (!CanImport || _preview == null) return;

        _importing = true;
        StateHasChanged();
        try
        {
            var account = await AccountService.ImportAccountAsync(_preview, _profileName.Trim());
            Snackbar.Add($"'{account.ProfileName}' 계정을 가져왔습니다.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(account));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"가져오기 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (_preview == null) await Decrypt();
        else await Import();
    }
}
