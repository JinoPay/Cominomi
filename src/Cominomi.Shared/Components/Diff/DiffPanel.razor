@inject ChatState ChatState
@inject IGitService GitService
@implements IDisposable

<MudDrawer Open="ChatState.IsDiffPanelOpen" OpenChanged="OnDrawerOpenChanged"
           Anchor="Anchor.End" ClipMode="DrawerClipMode.Always"
           Elevation="0" Variant="DrawerVariant.Temporary" Width="450px"
           Style="border-left: 1px solid var(--cominomi-border-subtle);">
    <div style="display: flex; flex-direction: column; height: 100%; overflow: hidden;">
        <div style="display: flex; align-items: center; padding: 12px 16px; flex-shrink: 0; gap: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.Difference" Size="Size.Small" Color="Color.Primary"
                     Style="width: 16px; height: 16px;" />
            <span class="diff-header-label" style="flex: 1;">변경사항</span>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           Style="width: 24px; height: 24px;"
                           OnClick="LoadDiffAsync" Disabled="_isLoading" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           Style="width: 24px; height: 24px;"
                           OnClick="@(() => ChatState.ToggleDiffPanel())" />
        </div>

        <div style="height: 1px; background: var(--cominomi-border-subtle);"></div>

        <div style="flex: 1; overflow-y: auto; padding: 8px;">
            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-4" />
            }
            else if (_error != null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">@_error</MudAlert>
            }
            else if (_diff == null || _diff.Files.Count == 0)
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 200px; gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large"
                             Style="opacity: 0.2;" />
                    <span style="font-size: 0.82rem; opacity: 0.35;">변경사항이 없습니다</span>
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; padding: 4px 12px 12px; gap: 8px;">
                    <span style="font-size: 0.75rem; opacity: 0.5;">
                        @(_diff.Files.Count)개 파일 변경됨
                    </span>
                    <span style="flex: 1;"></span>
                    <div class="diff-stats">
                        <span class="additions">+@(_diff.TotalAdditions)</span>
                        <span class="deletions">-@(_diff.TotalDeletions)</span>
                    </div>
                </div>

                @foreach (var file in _diff.Files)
                {
                    <div style="margin-bottom: 4px;">
                        <div class="diff-file-item" @onclick="@(() => ToggleFile(file.FilePath))">
                            <MudIcon Icon="@GetFileIcon(file.ChangeType)" Size="Size.Small"
                                     Style="@($"width: 16px; height: 16px; {GetFileIconStyle(file.ChangeType)}")" />
                            <span class="diff-file-path">@file.FilePath</span>
                            <div class="diff-stats">
                                @if (file.Additions > 0)
                                {
                                    <span class="additions">+@file.Additions</span>
                                }
                                @if (file.Deletions > 0)
                                {
                                    <span class="deletions">-@file.Deletions</span>
                                }
                            </div>
                            <MudIcon Icon="@(_expandedFiles.Contains(file.FilePath) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                     Size="Size.Small" Style="width: 16px; height: 16px; opacity: 0.4;" />
                        </div>

                        @if (_expandedFiles.Contains(file.FilePath))
                        {
                            <div class="diff-content" style="margin: 4px 0 8px 8px; border-radius: 6px; border: 1px solid var(--cominomi-border-subtle); overflow: hidden;">
                                @if (string.IsNullOrWhiteSpace(file.UnifiedDiff))
                                {
                                    <div style="padding: 12px; font-size: 0.78rem; opacity: 0.35;">
                                        비교할 수 없음 (바이너리 또는 빈 파일)
                                    </div>
                                }
                                else
                                {
                                    @foreach (var line in file.UnifiedDiff.Split('\n'))
                                    {
                                        <div class="diff-line @GetLineClass(line)">@line</div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</MudDrawer>

@code {
    private void OnDrawerOpenChanged(bool open)
    {
        if (!open && ChatState.IsDiffPanelOpen)
            ChatState.ToggleDiffPanel();
    }

    private DiffSummary? _diff;
    private bool _isLoading;
    private string? _error;
    private string? _lastSessionId;
    private HashSet<string> _expandedFiles = new();

    private void ToggleFile(string filePath)
    {
        if (!_expandedFiles.Remove(filePath))
            _expandedFiles.Add(filePath);
    }

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(() =>
        {
            var sessionId = ChatState.CurrentSession?.Id;
            if (ChatState.IsDiffPanelOpen && sessionId != _lastSessionId)
            {
                _lastSessionId = sessionId;
                _expandedFiles.Clear();
                _ = LoadDiffAsync();
            }
            StateHasChanged();
        });
    }

    private async Task LoadDiffAsync()
    {
        var session = ChatState.CurrentSession;
        if (session == null || session.Status == SessionStatus.Pending ||
            string.IsNullOrEmpty(session.WorktreePath) || string.IsNullOrEmpty(session.BaseBranch))
        {
            _diff = null;
            _error = null;
            StateHasChanged();
            return;
        }

        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var nameStatus = await GitService.GetNameStatusAsync(session.WorktreePath, session.BaseBranch);
            var rawDiff = await GitService.GetUnifiedDiffAsync(session.WorktreePath, session.BaseBranch);
            _diff = Services.GitService.ParseDiff(nameStatus, rawDiff);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _diff = null;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetFileIcon(FileChangeType type) => type switch
    {
        FileChangeType.Added => Icons.Material.Filled.NoteAdd,
        FileChangeType.Deleted => Icons.Material.Filled.Delete,
        FileChangeType.Renamed => Icons.Material.Filled.DriveFileRenameOutline,
        _ => Icons.Material.Filled.EditNote
    };

    private static string GetFileIconStyle(FileChangeType type) => type switch
    {
        FileChangeType.Added => "color: #a6e3a1;",
        FileChangeType.Deleted => "color: #f38ba8;",
        FileChangeType.Renamed => "color: #fab387;",
        _ => "color: #89b4fa;"
    };

    private static string GetLineClass(string line)
    {
        if (line.StartsWith("@@")) return "hunk";
        if (line.StartsWith('+') && !line.StartsWith("+++")) return "addition";
        if (line.StartsWith('-') && !line.StartsWith("---")) return "deletion";
        return "";
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
