@inject ICliAvailabilityService CliAvailability

<div class="settings-section-title">AI 모델</div>
<div class="settings-section-desc">AI 모델 및 동작 방식을 설정합니다.</div>

<div class="stack gap-3">
    <div class="settings-section-title" style="font-size: 0.8rem; opacity: 0.6; margin-bottom: -8px;">Claude</div>

    <MudSelect T="string" @bind-Value="Settings.DefaultModel" Label="기본 모델"
               Variant="Variant.Outlined" Margin="Margin.Dense"
               MaxHeight="400"
               HelperText="전역 기본값입니다. 워크스페이스별로 다른 모델을 지정할 수 있습니다.">
        @foreach (var model in ModelDefinitions.All.Where(m => m.Provider != "codex"))
        {
            <MudSelectItem T="string" Value="@model.Id">
                <div class="model-select-option">
                    <div class="model-select-name">
                        <span>@model.DisplayName</span>
                        @if (model.Pricing != null)
                        {
                            <span class="model-select-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                        }
                        else if (model.IsAlias)
                        {
                            <span class="model-select-price" style="opacity: 0.5;">alias</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(model.Description))
                    {
                        <span class="model-select-desc" title="@model.Description">@model.Description</span>
                    }
                </div>
            </MudSelectItem>
        }
    </MudSelect>

    <div>
        <div class="settings-field-label">기본 Effort 레벨</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "auto" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "auto")">Auto</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel != "auto" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = ModelDefinitions.GetMaxEffortLevel(Settings.DefaultModel))">최대</button>
        </div>
        <div class="settings-field-hint">auto: 모델 기본값, 최대: 모델별 최고 사고 수준 (Opus: max, 그 외: high)</div>
    </div>

    <div>
        <div class="settings-field-label">기본 권한 모드</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "bypassAll" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "bypassAll")">일반 모드</button>
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "plan" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "plan")">플랜 모드</button>
        </div>
        <div class="settings-field-hint">Seoro에서 Claude CLI 실행 시 적용되는 권한 모드입니다.</div>
    </div>

    <MudTextField @bind-Value="Settings.FallbackModel" Label="Fallback 모델"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="sonnet"
                  HelperText="기본 모델 과부하 시 대체 모델 (비워두면 미사용)"/>

    <MudTextField @bind-Value="Settings.McpConfigPath" Label="MCP 설정 파일 경로"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="./mcp.json"
                  HelperText="MCP 서버 설정 JSON 파일 경로 (비워두면 미사용)"/>

    @if (_codexAvailable)
    {
        <div class="settings-section-title" style="font-size: 0.8rem; opacity: 0.6; margin-top: 8px; margin-bottom: -8px;">Codex</div>

        <MudSelect T="string" @bind-Value="Settings.DefaultCodexModel" Label="Codex 기본 모델"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   MaxHeight="400"
                   HelperText="Codex 세션의 전역 기본 모델입니다.">
            @foreach (var model in ModelDefinitions.All.Where(m => m.Provider == "codex"))
            {
                <MudSelectItem T="string" Value="@model.Id">
                    <div class="model-select-option">
                        <div class="model-select-name">
                            <span>@model.DisplayName</span>
                            @if (model.Pricing != null)
                            {
                                <span class="model-select-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(model.Description))
                        {
                            <span class="model-select-desc" title="@model.Description">@model.Description</span>
                        }
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <div>
            <div class="settings-field-label">Reasoning Effort</div>
            <div class="settings-segmented">
                @foreach (var level in _codexReasoningLevels)
                {
                    <button class="settings-seg-item @(Settings.CodexReasoningEffort == level.Key ? "active" : "")"
                            @onclick="@(() => Settings.CodexReasoningEffort = level.Key)">@level.Value</button>
                }
            </div>
            <div class="settings-field-hint">Codex 모델의 추론 깊이를 설정합니다.</div>
        </div>

        <div>
            <div class="settings-field-label">Sandbox 모드</div>
            <div class="settings-segmented">
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "read-only" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "read-only")">읽기 전용</button>
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "workspace-write" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "workspace-write")">워크스페이스</button>
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "danger-full-access" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "danger-full-access")">전체 접근</button>
            </div>
            <div class="settings-field-hint">파일 시스템 접근 범위를 설정합니다.</div>
        </div>

        <div>
            <div class="settings-field-label">승인 정책</div>
            <div class="settings-segmented">
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "untrusted" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "untrusted")">항상 승인</button>
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "on-request" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "on-request")">요청 시</button>
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "never" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "never")">자동</button>
            </div>
            <div class="settings-field-hint">명령 실행 전 사용자 승인 시점을 설정합니다.</div>
        </div>

        <div>
            <MudSwitch @bind-Value="Settings.CodexWebSearch" Label="웹 검색" Color="Color.Primary"/>
            <div class="settings-field-hint" style="margin-top: -8px;">Codex 세션에서 웹 검색을 활성화합니다.</div>
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private bool _codexAvailable;

    private static readonly Dictionary<string, string> _codexReasoningLevels = new()
    {
        ["minimal"] = "최소",
        ["low"] = "낮음",
        ["medium"] = "보통",
        ["high"] = "높음",
        ["xhigh"] = "최대"
    };

    protected override async Task OnInitializedAsync()
    {
        _codexAvailable = await CliAvailability.IsAvailableAsync("codex");
    }
}
