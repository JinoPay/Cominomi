<div class="stack gap-3">
    <div class="settings-group settings-group-link" @onclick="@(() => _pluginManagerOpen = true)">
        <div class="stack-row items-center gap-3">
            <div class="settings-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.Extension" Size="Size.Small"
                         Style="color: var(--accent);"/>
            </div>
            <div style="flex: 1;">
                <div class="typo-subtitle2">플러그인</div>
                <div class="typo-caption text-secondary">플러그인 설치, 활성화/비활성화, 제거를 관리합니다.</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                     Style="color: var(--text-muted);"/>
        </div>
    </div>
</div>

<PluginManagerDialog @bind-IsOpen="_pluginManagerOpen"/>

@code {
    private bool _pluginManagerOpen;
}
