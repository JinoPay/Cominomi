@inject IChatState ChatState
@inject IMergeStatusService MergeStatusService
@inject IWorkspaceService WorkspaceService
@inject IChatEventBus EventBus
@implements IDisposable

@*
    슬림 MergeToolbar (36px) — 상태 아이콘 + 한 줄 요약만 표시.
    클릭 시 EmbeddedDiffPanel 의 Merge 탭으로 전환 (MergeTabRequestedEvent).
    상세 머지 컨트롤은 MergePanel.razor (Merge 탭 내부) 에서 처리.
*@

<div class="merge-toolbar" @onclick="HandleToolbarClick" title="클릭하여 Merge 탭 열기">
    @{
        var session = ChatState.CurrentSession;
        var workspace = ChatState.CurrentWorkspace;
    }
    @if (session != null && session.Status != SessionStatus.Pending)
    {
        var status = MergeStatusService.GetCurrent(session.Id);
        var remoteInfo = workspace != null ? WorkspaceService.GetRemoteInfo(workspace.Id) : RemoteInfo.None;

        <span class="merge-status-icon @MergePanel.StatusCssClass(status.Kind)">
            <MudIcon Icon="@MergePanel.StatusIcon(status.Kind)" Style="width: 14px; height: 14px;"/>
        </span>

        @if (session.Git.IsLocalDir)
        {
            <span class="merge-toolbar-label">
                @BuildLocalDirSummary(status, remoteInfo)
            </span>
        }
        else
        {
            <span class="merge-toolbar-label">
                @BuildWorktreeSummary(session, status)
            </span>

            @if (session.Git.TrackedPr != null)
            {
                var pr = session.Git.TrackedPr;
                <span class="pr-badge @PrBadgeCssClass(pr)" style="flex-shrink: 0;">
                    <MudIcon Icon="@PrStatusIcon(pr)" Style="width: 11px; height: 11px;"/>
                    <span>#@pr.Number</span>
                </span>
            }
        }

        <MudIcon Icon="@Icons.Material.Filled.ChevronRight"
                 Style="width: 14px; height: 14px; opacity: 0.3; flex-shrink: 0; margin-left: auto;"/>
    }
</div>

@code {
    private IDisposable? _statusChangedSub;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
        MergeStatusService.StatusChanged += HandleMergeStatusChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private void HandleMergeStatusChanged(string sessionId)
    {
        var current = ChatState.CurrentSession;
        if (current == null || current.Id != sessionId) return;
        InvokeAsync(StateHasChanged);
    }

    private void HandleToolbarClick()
    {
        EventBus.Publish(new MergeTabRequestedEvent());
    }

    private static string BuildLocalDirSummary(MergeStatus status, RemoteInfo remoteInfo)
    {
        var parts = new List<string>();
        if ((status.AheadCount ?? 0) > 0)
            parts.Add($"↑{status.AheadCount}");
        if (status.UncommittedChangeCount > 0)
            parts.Add($"{status.UncommittedChangeCount}변경");
        var prefix = parts.Count > 0 ? string.Join(" · ", parts) + " — " : "";
        return $"{prefix}로컬 디렉토리";
    }

    private static string BuildWorktreeSummary(Session session, MergeStatus status)
    {
        var branch = session.Git.BranchName ?? "";
        var target = MergeStatusService_GetTargetLabel(status);
        var statusText = status.Kind switch
        {
            MergeStatusKind.Clean => "머지 가능",
            MergeStatusKind.BehindTarget => $"↓{status.BehindCount ?? 0} 뒤처짐",
            MergeStatusKind.ConflictExpected => $"충돌 {status.ConflictingFiles?.Count ?? 0}개 예상",
            MergeStatusKind.UncommittedDirty => $"변경 {status.UncommittedChangeCount}개",
            MergeStatusKind.InConflict => "충돌 진행 중",
            MergeStatusKind.NetworkError => "오프라인",
            _ => "확인 중..."
        };

        if (!string.IsNullOrEmpty(target))
            return $"{branch} → {target} · {statusText}";
        return $"{branch} · {statusText}";
    }

    private static string MergeStatusService_GetTargetLabel(MergeStatus status)
    {
        // 툴바는 타겟 브랜치를 직접 관리하지 않으므로 상태에서 추출 불가 — 빈 문자열 반환.
        // 실제 타겟은 MergePanel 에서 관리됨.
        return "";
    }

    private static string PrStatusIcon(TrackedPullRequest pr) => pr switch
    {
        { IsDraft: true } => Icons.Material.Outlined.EditNote,
        { IsMerged: true } => Icons.Material.Filled.CheckCircle,
        { IsMergeable: true } => Icons.Material.Filled.CheckCircle,
        { IsMergeable: false } => Icons.Material.Filled.Error,
        _ => Icons.Material.Outlined.HourglassEmpty
    };

    private static string PrBadgeCssClass(TrackedPullRequest pr) => pr switch
    {
        { IsMerged: true } => "pr-badge-merged",
        { IsDraft: true } => "pr-badge-draft",
        { IsMergeable: true } => "pr-badge-mergeable",
        { IsMergeable: false, MergeStateStatus: "BLOCKED" } => "pr-badge-blocked",
        { IsMergeable: false } => "pr-badge-conflict",
        _ => "pr-badge-unknown"
    };

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        MergeStatusService.StatusChanged -= HandleMergeStatusChanged;
    }
}
