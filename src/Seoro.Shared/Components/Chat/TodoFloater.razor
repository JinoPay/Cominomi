@* 우하단 떠있는 TodoWrite 진행 위젯 (Chip ↔ Expanded 카드) *@
@if (State == TodoFloaterVisibility.Chip && Snapshot is { Total: > 0 })
{
    <button class="todo-floater todo-floater-chip @(Snapshot.HasInProgress ? "has-progress" : "") @(Snapshot.AllDone ? "all-done" : "")"
            @onclick="HandleExpand"
            type="button"
            title="@Strings.Todo_FloaterTitle">
        @if (Snapshot.AllDone)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                     Color="Color.Success" Style="width: 18px; height: 18px;"/>
        }
        else if (Snapshot.HasInProgress)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Color="Color.Warning"
                                 Style="width: 16px; height: 16px;"/>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Checklist" Size="Size.Small"
                     Style="width: 18px; height: 18px;"/>
        }
        <span class="todo-floater-chip-count">@Snapshot.Completed / @Snapshot.Total</span>
        <MudIcon Icon="@Icons.Material.Filled.ExpandLess" Size="Size.Small"
                 Style="width: 16px; height: 16px; opacity: 0.6;"/>
    </button>
}
else if (State == TodoFloaterVisibility.Expanded && Snapshot is { Total: > 0 })
{
    <div class="todo-floater todo-floater-card">
        <div class="todo-floater-header" @onclick="HandleCollapse">
            <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small"
                     Style="width: 16px; height: 16px; opacity: 0.7;"/>
            <MudIcon Icon="@Icons.Material.Filled.Checklist" Size="Size.Small"
                     Style="width: 16px; height: 16px; opacity: 0.7;"/>
            <span class="todo-floater-title">@Strings.Todo_FloaterTitle</span>
            <span class="todo-floater-counter">@Snapshot.Completed / @Snapshot.Total</span>
            <button class="todo-floater-close"
                    @onclick="HandleDismiss"
                    @onclick:stopPropagation="true"
                    type="button"
                    title="@Strings.Common_Close">
                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                         Style="width: 14px; height: 14px;"/>
            </button>
        </div>
        <div class="todo-floater-progress">
            <div class="todo-floater-progress-fill" style="width: @ProgressPercent%;"></div>
        </div>
        <div class="todo-floater-list">
            @foreach (var entry in Snapshot.Entries)
            {
                <div class="todo-floater-row todo-status-@entry.Status.ToString().ToLowerInvariant()">
                    @switch (entry.Status)
                    {
                        case TodoStatus.Completed:
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                     Color="Color.Success"
                                     Style="width: 16px; height: 16px;"/>
                            break;
                        case TodoStatus.InProgress:
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Color="Color.Warning"
                                                 Style="width: 14px; height: 14px;"/>
                            break;
                        default:
                            <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" Size="Size.Small"
                                     Style="width: 16px; height: 16px; opacity: 0.4;"/>
                            break;
                    }
                    <span class="todo-floater-text">@GetDisplayText(entry)</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public TodoSnapshot? Snapshot { get; set; }
    [Parameter] public TodoFloaterVisibility State { get; set; }
    [Parameter] public EventCallback OnRequestExpand { get; set; }
    [Parameter] public EventCallback OnRequestCollapse { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }

    private int ProgressPercent =>
        Snapshot is { Total: > 0 } s ? (int)Math.Round(s.Completed * 100.0 / s.Total) : 0;

    private Task HandleExpand() => OnRequestExpand.InvokeAsync();
    private Task HandleCollapse() => OnRequestCollapse.InvokeAsync();
    private Task HandleDismiss() => OnDismiss.InvokeAsync();

    private static string GetDisplayText(TodoEntry entry)
    {
        return entry.Status == TodoStatus.InProgress && !string.IsNullOrEmpty(entry.ActiveForm)
            ? entry.ActiveForm
            : entry.Content;
    }
}
