@using Markdig
@using Seoro.Shared.Helpers
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="filediff-view">
    <div class="filediff-header">
        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small"
                 Style="width: 16px; height: 16px; opacity: 0.5;"/>
        <span class="filediff-path">@FilePath</span>
    </div>

    @if (string.IsNullOrEmpty(Content))
    {
        <div class="filecontent-body">
            <div class="filediff-empty">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.3;"/>
                <span>빈 파일</span>
            </div>
        </div>
    }
    else if (_viewMode == FileViewMode.Markdown)
    {
        <div class="filecontent-markdown">
            <div id="@_elementId" class="filecontent-markdown-inner markdown-body">
                @((MarkupString)_renderedHtml)
            </div>
        </div>
    }
    else if (_viewMode == FileViewMode.Code)
    {
        <div id="@_elementId" class="cm-host"></div>
    }
    else
    {
        <div class="filecontent-body">
            @{
                var lines = Content.Split('\n');
            }
            @for (var i = 0; i < lines.Length; i++)
            {
                var lineNum = i + 1;
                var line = lines[i];
                <div class="filecontent-line">
                    <span class="filecontent-linenum">@lineNum</span>
                    <span class="filecontent-text">@line</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public string FilePath { get; set; } = "";

    [Parameter][EditorRequired] public string Content { get; set; } = "";

    private enum FileViewMode
    {
        Code,
        Markdown,
        PlainText
    }

    private FileViewMode _viewMode;
    private string _language = "";
    private string _elementId = "";
    private string _renderedHtml = "";
    private bool _needsHighlight;
    private string? _lastFilePath;


    protected override void OnParametersSet()
    {
        if (_lastFilePath == FilePath) return;
        _lastFilePath = FilePath;

        // UI 멈춤을 피하기 위해 큰 파일은 일반 텍스트로 폴백합니다
        if (Content.Length > 500_000)
        {
            _viewMode = FileViewMode.PlainText;
            return;
        }

        _viewMode = GetViewMode(FilePath);
        _language = GetLanguage(FilePath);
        _elementId = $"cm-{FilePath.GetHashCode():x8}";

        if (_viewMode == FileViewMode.Markdown && !string.IsNullOrEmpty(Content))
        {
            _renderedHtml = Markdown.ToHtml(Content, MarkdownHelper.TrustedPipeline);
        }

        _needsHighlight = (_viewMode == FileViewMode.Code || _viewMode == FileViewMode.Markdown) && !string.IsNullOrEmpty(Content);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsHighlight)
        {
            _needsHighlight = false;
            try
            {
                if (_viewMode == FileViewMode.Markdown)
                    await JS.InvokeVoidAsync("enhanceMarkdownCodeBlocks", _elementId, false);
                else
                    await JS.InvokeVoidAsync("createCodeMirrorView", _elementId, Content, _language, true);
            }
            catch
            {
                // JS interop이 처리 중에 실패할 수 있습니다
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_viewMode == FileViewMode.Code && !string.IsNullOrEmpty(_elementId))
        {
            try
            {
                await JS.InvokeVoidAsync("destroyCodeMirrorView", _elementId);
            }
            catch
            {
                // 폐기 중에 JS interop이 실패할 수 있습니다
            }
        }
    }

    private static FileViewMode GetViewMode(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".md" or ".mdx" => FileViewMode.Markdown,
            ".cs" or ".js" or ".jsx" or ".ts" or ".tsx" or ".py" or ".rs" or ".go"
                or ".java" or ".html" or ".razor" or ".css" or ".scss" or ".json"
                or ".yaml" or ".yml" or ".xml" or ".csproj" or ".sln" or ".rb"
                or ".swift" or ".kt" or ".dart" or ".php" or ".sql" or ".sh"
                or ".bash" or ".zsh" or ".ps1" or ".dockerfile" or ".toml"
                or ".ini" or ".cfg" or ".vue" or ".svelte" or ".c" or ".cpp"
                or ".h" or ".hpp" or ".m" or ".mm" or ".r" or ".lua" or ".pl"
                or ".makefile" or ".gradle" or ".graphql" or ".proto"
                or ".xaml"
                => FileViewMode.Code,
            _ => FileViewMode.PlainText
        };
    }

    private static string GetLanguage(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".rs" => "rust",
            ".go" => "go",
            ".java" => "java",
            ".html" or ".razor" => "xml",
            ".css" or ".scss" => "css",
            ".json" => "json",
            ".yaml" or ".yml" => "yaml",
            ".xml" or ".csproj" or ".sln" or ".xaml" => "xml",
            ".sh" or ".bash" or ".zsh" => "bash",
            ".sql" => "sql",
            ".rb" => "ruby",
            ".swift" => "swift",
            ".kt" => "kotlin",
            ".dart" => "dart",
            ".php" => "php",
            ".dockerfile" => "dockerfile",
            ".toml" or ".ini" or ".cfg" => "ini",
            ".c" or ".cpp" or ".h" or ".hpp" => "cpp",
            ".m" or ".mm" => "objectivec",
            ".r" => "r",
            ".lua" => "lua",
            ".pl" => "perl",
            ".makefile" => "makefile",
            ".graphql" => "graphql",
            ".proto" => "protobuf",
            _ => ""
        };
    }

}
