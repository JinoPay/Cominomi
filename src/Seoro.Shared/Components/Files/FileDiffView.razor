@inject IJSRuntime JS
@inject IGitService GitService
@inject IChatState ChatState

<div class="filediff-view">
    <div class="filediff-header">
        <MudIcon Icon="@GetFileIcon(Diff.ChangeType)" Size="Size.Small"
                 Style="@($"width: 16px; height: 16px; {GetFileIconStyle(Diff.ChangeType)}")"/>
        <span class="filediff-path">@Diff.FilePath</span>
        <div class="diff-stats" style="margin-left: auto;">
            @if (Diff.Additions > 0)
            {
                <span class="additions">+@Diff.Additions</span>
            }
            @if (Diff.Deletions > 0)
            {
                <span class="deletions">-@Diff.Deletions</span>
            }
        </div>
    </div>

    <div id="@_elementId" class="filediff-content">
        @if (_parsed == null || _parsed.Hunks.Count == 0)
        {
            @if (string.IsNullOrWhiteSpace(Diff.UnifiedDiff))
            {
                <div class="filediff-empty">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.3;"/>
                    <span>사용 가능한 diff가 없습니다</span>
                </div>
            }
        }
        else
        {
            @foreach (var hunk in _parsed.Hunks)
            {
                var hasGap = hunk.GapEndLine > hunk.GapStartLine;

                @* 확장된 간격 라인 *@
                @if (hunk is { IsExpanded: true, ExpandedLines: not null })
                {
                    @foreach (var line in hunk.ExpandedLines)
                    {
                        <div class="diff-line expanded-context"><span class="diff-prefix"> </span><span
                                class="diff-code">@line.Text</span></div>
                    }
                }

                @* Hunk 헤더 *@
                @if (hasGap)
                {
                    <div class="diff-line hunk expandable" @onclick="() => ToggleHunkAsync(hunk)">
                        <span class="hunk-expand-icon @(hunk.IsExpanded ? "expanded" : "")">▶</span>
                        <span class="diff-code">@hunk.HeaderText</span>
                    </div>
                }
                else
                {
                    <div class="diff-line hunk">
                        <span class="diff-code">@hunk.HeaderText</span>
                    </div>
                }

                @* 이 hunk의 diff 라인 *@
                @foreach (var line in hunk.Lines)
                {
                    var cls = GetLineClass(line.Type);
                    <div class="diff-line @cls"><span class="diff-prefix">@line.Prefix</span><span
                            class="diff-code">@line.Text</span></div>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter][EditorRequired] public FileDiff Diff { get; set; } = null!;

    private string _elementId = "";
    private string _language = "";
    private bool _needsHighlight;
    private string? _lastFilePath;
    private ParsedDiff? _parsed;

    protected override void OnParametersSet()
    {
        var filePath = Diff.FilePath;
        if (_lastFilePath == filePath) return;
        _lastFilePath = filePath;

        _elementId = $"diff-{filePath.GetHashCode():x8}";
        _language = GetLanguage(filePath);
        _parsed = DiffParser.Parse(Diff.UnifiedDiff);
        _needsHighlight = _parsed.Hunks.Count > 0 && _language.Length > 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsHighlight)
        {
            _needsHighlight = false;
            try
            {
                await JS.InvokeVoidAsync("highlightDiffBlock", _elementId, _language);
            }
            catch
            {
                // JS interop이 처리 중에 실패할 수 있습니다
            }
        }
    }

    private async Task ToggleHunkAsync(DiffHunk hunk)
    {
        if (hunk.IsExpanded)
        {
            hunk.IsExpanded = false;
            hunk.ExpandedLines = null;
            return;
        }

        var session = ChatState.CurrentSession;
        if (session == null) return;

        var worktreePath = session.Git.WorktreePath;
        var baseBranch = session.Git.GetDiffBase();

        try
        {
            string[] lines;
            if (Diff.ChangeType == FileChangeType.Deleted)
            {
                lines = await GitService.ReadBaseFileLinesAsync(
                    worktreePath, baseBranch, Diff.FilePath,
                    hunk.GapStartLine, hunk.GapEndLine);
            }
            else
            {
                lines = await GitService.ReadFileLinesAsync(
                    worktreePath, Diff.FilePath,
                    hunk.GapStartLine, hunk.GapEndLine);
            }

            hunk.ExpandedLines = lines.Select(l => new DiffLine
            {
                Type = DiffLineType.Context,
                Prefix = " ",
                Text = l
            }).ToList();
            hunk.IsExpanded = true;

            _needsHighlight = _language.Length > 0;
        }
        catch
        {
            // 파일이 존재하지 않거나 접근할 수 없을 수 있습니다
        }
    }

    private static string GetLineClass(DiffLineType type)
    {
        return type switch
        {
            DiffLineType.Addition => "addition",
            DiffLineType.Deletion => "deletion",
            DiffLineType.Hunk => "hunk",
            _ => ""
        };
    }

    private static string GetFileIcon(FileChangeType type)
    {
        return type switch
        {
            FileChangeType.Added => Icons.Material.Filled.NoteAdd,
            FileChangeType.Deleted => Icons.Material.Filled.Delete,
            FileChangeType.Renamed => Icons.Material.Filled.DriveFileRenameOutline,
            FileChangeType.Untracked => Icons.Material.Filled.AddCircleOutline,
            _ => Icons.Material.Filled.EditNote
        };
    }

    private static string GetFileIconStyle(FileChangeType type)
    {
        return type switch
        {
            FileChangeType.Added => "color: var(--color-success);",
            FileChangeType.Deleted => "color: var(--color-error);",
            FileChangeType.Renamed => "color: var(--color-warning);",
            FileChangeType.Untracked => "color: var(--mud-palette-text-secondary);",
            _ => "color: var(--color-info);"
        };
    }

    private static string GetLanguage(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".rs" => "rust",
            ".go" => "go",
            ".java" => "java",
            ".html" or ".razor" => "xml",
            ".css" or ".scss" => "css",
            ".json" => "json",
            ".yaml" or ".yml" => "yaml",
            ".xml" or ".csproj" or ".sln" => "xml",
            ".sh" or ".bash" or ".zsh" => "bash",
            ".sql" => "sql",
            ".rb" => "ruby",
            ".swift" => "swift",
            ".kt" => "kotlin",
            ".dart" => "dart",
            ".php" => "php",
            ".dockerfile" => "dockerfile",
            ".toml" or ".ini" or ".cfg" => "ini",
            ".c" or ".cpp" or ".h" or ".hpp" => "cpp",
            ".m" or ".mm" => "objectivec",
            ".r" => "r",
            ".lua" => "lua",
            ".pl" => "perl",
            ".makefile" => "makefile",
            ".graphql" => "graphql",
            ".proto" => "protobuf",
            _ => ""
        };
    }

}
